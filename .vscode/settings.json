{
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "debug.javascript.terminalOptions": {
    "skipFiles": [
      "<node_internals>/**",
      "**/node_modules/**"
    ]
  },
  "cSpell.language": "en",
  "cSpell.enabledFileTypes": {
    "typescript": true,
    "markdown": true
  },
  "cSpell.words": [
    "misbehaviors",
    "sourcemaps"
  ]
}
